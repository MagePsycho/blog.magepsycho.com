WARDEN_ENV_NAME=blog
WARDEN_ENV_TYPE=wordpress
WARDEN_WEB_ROOT=/

TRAEFIK_DOMAIN=blog.test
TRAEFIK_SUBDOMAIN=

MYSQL_DISTRIBUTION=mariadb
MYSQL_DISTRIBUTION_VERSION=11.4
NODE_VERSION=22
COMPOSER_VERSION=2
PHP_VERSION=8.4
PHP_XDEBUG_3=1

WARDEN_DB=1
WARDEN_REDIS=1
WARDEN_PHP_SPX=0

APP_ENV=local
APP_DEBUG=true

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=wordpress
DB_USERNAME=wordpress
DB_PASSWORD=wordpress

WARDEN_DOCKER_SOCK=/Users/rajkb/.orbstack/run/docker.sock
